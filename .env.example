# =============================================================
# APPLICATION
# =============================================================

# Docker Hub image with SHA tag — set by CI/CD pipeline
DOCKER_IMAGE=yourdockerhubuser/webhook-delivery:sha-abc123

#This is the one we have put in env file as of now becuase we are not yet in cicd pipleine
DOCKER_IMAGE=vimukthirandunu/webhook-delivery-system:v1

# =============================================================
# DATABASE — Instance 2 private IP
# =============================================================

DATABASE_URL=postgresql://webhookuser:yourpassword@10.0.1.45:5432/webhooks

POSTGRES_USER=webhookuser
POSTGRES_PASSWORD=yourpassword
POSTGRES_DB=webhooks

# =============================================================
# REDIS — local to Instance 1
# =============================================================

REDIS_URL=redis://redis:6379

# =============================================================
# OBSERVABILITY
# =============================================================

GRAFANA_PASSWORD=yourgrafanapassword

# =============================================================
# DOMAIN
# =============================================================

DOMAIN=yourdomain.com